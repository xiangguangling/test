{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": [
    "src/components/BottomSchoolsList.tsx",
    "src/components/CrisisAlert.tsx",
    "src/components/FacilityAnalysis.tsx",
    "src/components/FacilityGrid.tsx",
    "src/components/FacultyGrid.tsx",
    "src/components/IndicatorRadar.tsx",
    "src/components/IndicatorSunburst.tsx",
    "src/components/OverviewCards.tsx",
    "src/components/RegionalGrid.tsx",
    "src/components/ScoreDistribution.tsx"
  ]
}
